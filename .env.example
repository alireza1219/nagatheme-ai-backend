NAGATHEME_AUTH_PREFIX=
NAGATHEME_API_KEY=
NAGATHEME_ENDPOINT=
NAGATHEME_AI_VISION_ENDPOINT=
NAGATHEME_AI_VISION_MODEL=gpt-4o

DEFAULT_MODEL=gpt-5-nano
DEFAULT_TEMPERATURE=0.7
DEFAULT_MAX_TOKENS=4096
REASONING_MAX_TOKENS=16000
REASONING_EFFORT=medium
IMAGE_CREDIT_COST=50

# Show detailed errors in response body (set true ONLY in development)
DISPLAY_ERROR_DETAILS=false
# Log errors to error log
LOG_ERRORS=false
# Include full stack trace
LOG_ERROR_DETAILS=false

# Logging
LOG_LEVEL=info
LOG_TO_FILE=false
LOG_FILE=/var/log/ai_api.log